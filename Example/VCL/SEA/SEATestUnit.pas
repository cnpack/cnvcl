// Get coefficient [m,n] from BiPolynomial, handling symmetry (m<n returns [n,m])
function GetCoeff(P: TCnBigNumberBiPolynomial; M, N: Integer): TCnBigNumber;
begin
  if M >= N then
    Result := P.ReadonlyValue[M, N]
  else
    Result := P.ReadonlyValue[N, M];
end;

// Compare computed polynomial against embedded MIT data string
function CompareWithEmbedded(P: TCnBigNumberBiPolynomial; const MitData: string): Integer;
var
  SL: TStringList;
  I, M, N, SpPos, Comma: Integer;
  Line, Key, ValStr: string;
  Expected: TCnBigNumber;
  Actual: TCnBigNumber;
  Matched: Boolean;
begin
  Result := 0;
  SL := TStringList.Create;
  Expected := TCnBigNumber.Create;
  try
    // Split MitData by #10 into lines
    SL.Text := StringReplace(MitData, #10, sLineBreak, [rfReplaceAll]);

    WriteLn(Format('  Comparing %d MIT entries', [SL.Count]));

    for I := 0 to SL.Count - 1 do
    begin
      Line := Trim(SL[I]);
      if Line = '' then Continue;

      // Parse [m,n] value
      SpPos := Pos('] ', Line);
      if SpPos = 0 then Continue;
      Key := Copy(Line, 1, SpPos);  // [m,n]
      ValStr := Trim(Copy(Line, SpPos + 1, MaxInt));

      // Extract m and n from [m,n]
      Key := StringReplace(Key, '[', '', [rfReplaceAll]);
      Key := StringReplace(Key, ']', '', [rfReplaceAll]);
      Key := StringReplace(Key, ' ', '', [rfReplaceAll]);
      Comma := Pos(',', Key);
      M := StrToInt(Copy(Key, 1, Comma - 1));
      N := StrToInt(Copy(Key, Comma + 1, MaxInt));

      Expected.SetDec(ValStr);
      Actual := GetCoeff(P, M, N);  // readonly reference, do not free

      Matched := BigNumberCompare(Expected, Actual) = 0;
      if not Matched then
      begin
        Inc(Result);
        WriteLn(Format('  MISMATCH [%d,%d]: MIT=%s  Ours=%s',
          [M, N, Expected.ToDec, Actual.ToDec]));
      end;
    end;

    if Result = 0 then
      WriteLn('  MIT comparison: ALL MATCH')
    else
      WriteLn(Format('  MIT comparison: %d mismatches', [Result]));
  finally
    Expected.Free;
    SL.Free;
  end;
end;

procedure RunModularPolynomialTest(L: Integer; const MitData: string);
var
  Poly: TCnBigNumberBiPolynomial;
begin
  WriteLn;
  WriteLn('===== Phi_' + IntToStr(L) + '(X, Y) =====');
  Poly := TCnBigNumberBiPolynomial.Create;
  try
    if CnGenerateClassicalModularPolynomial(Poly, L) then
    begin
      WriteLn('MaxXDegree=' + IntToStr(Poly.MaxXDegree) +
              ' MaxYDegree=' + IntToStr(Poly.MaxYDegree));
      CompareWithEmbedded(Poly, MitData);
    end
    else
      WriteLn('FAILED to generate Phi_' + IntToStr(L));
  finally
    Poly.Free;
  end;
end;

