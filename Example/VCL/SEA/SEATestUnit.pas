procedure TestJInvariant;
var
  A, B, P, J: TCnBigNumber;
begin
  WriteLn;
  WriteLn('===== Test CnSeaJInvariant =====');
  A := TCnBigNumber.Create;
  B := TCnBigNumber.Create;
  P := TCnBigNumber.Create;
  J := TCnBigNumber.Create;
  try
    A.SetWord(1);
    B.SetWord(1);
    P.SetWord(5);
    if CnSeaJInvariant(J, A, B, P) then
      WriteLn(Format('  E: y^2=x^3+x+1 over F_5, j = %s (expected 2)', [J.ToDec]))
    else
      WriteLn('  FAILED to compute j-invariant');

    A.SetWord(2);
    B.SetWord(2);
    P.SetWord(17);
    if CnSeaJInvariant(J, A, B, P) then
      WriteLn(Format('  E: y^2=x^3+2x+2 over F_17, j = %s', [J.ToDec]))
    else
      WriteLn('  FAILED to compute j-invariant');

  finally
    J.Free;
    P.Free;
    B.Free;
    A.Free;
  end;
end;

procedure TestPrimeType;
const
  Ls: array[0..4] of Integer = (3, 5, 7, 11, 13);
var
  A, B, P: TCnBigNumber;
  L, Idx: Integer;
  PT: TCnSeaPrimeType;
  TypeStr: string;
begin
  WriteLn;
  WriteLn('===== Test CnSeaCheckPrimeType =====');
  A := TCnBigNumber.Create;
  B := TCnBigNumber.Create;
  P := TCnBigNumber.Create;
  try
    A.SetWord(2);
    B.SetWord(2);
    P.SetWord(17);
    WriteLn('  Curve: y^2=x^3+2x+2 over F_17:');
    for Idx := Low(Ls) to High(Ls) do
    begin
      L := Ls[Idx];
      PT := CnSeaCheckPrimeType(L, A, B, P);
      case PT of
        sptElkies: TypeStr := 'Elkies';
        sptAtkin:  TypeStr := 'Atkin';
        sptFailed: TypeStr := 'Failed';
      end;
      WriteLn(Format('    L=%d: %s', [L, TypeStr]));
    end;

    A.SetWord(3);
    B.SetWord(5);
    P.SetWord(97);
    WriteLn('  Curve: y^2=x^3+3x+5 over F_97:');
    for Idx := Low(Ls) to High(Ls) do
    begin
      L := Ls[Idx];
      PT := CnSeaCheckPrimeType(L, A, B, P);
      case PT of
        sptElkies: TypeStr := 'Elkies';
        sptAtkin:  TypeStr := 'Atkin';
        sptFailed: TypeStr := 'Failed';
      end;
      WriteLn(Format('    L=%d: %s', [L, TypeStr]));
    end;

  finally
    P.Free;
    B.Free;
    A.Free;
  end;
end;

procedure TestElkiesTrace;
const
  Ls: array[0..3] of Integer = (3, 5, 7, 11);
var
  A, B, P, Trace: TCnBigNumber;
  L, Idx: Integer;
  PT: TCnSeaPrimeType;
  H: TCnBigNumberPolynomial;
  I: Integer;
  SL: TStringList;
begin
  WriteLn;
  WriteLn('===== Test CnSeaElkiesTrace =====');
  A := TCnBigNumber.Create;
  B := TCnBigNumber.Create;
  P := TCnBigNumber.Create;
  Trace := TCnBigNumber.Create;
  H := TCnBigNumberPolynomial.Create;
  SL := TStringList.Create;
  try
    A.SetWord(3);
    B.SetWord(5);
    P.SetWord(97);

    for Idx := Low(Ls) to High(Ls) do
    begin
      L := Ls[Idx];
      PT := CnSeaCheckPrimeType(L, A, B, P);
      if PT = sptElkies then
      begin
        WriteLn(Format('  L=%d (Elkies):', [L]));

        if CnSeaElkiesKernelPolynomial(H, L, A, B, P) then
        begin
          WriteLn(Format('    Kernel poly degree: %d (expected %d)', [H.MaxDegree, (L-1) div 2]));
          SL.Clear;
          for I := 0 to H.MaxDegree do
            SL.Add(Format('  h[%d] = %s', [I, H[I].ToDec]));
          WriteLn('    h(x) =' + SL.Text);
        end
        else
          WriteLn('    Kernel poly FAILED');

        if CnSeaElkiesTrace(Trace, L, A, B, P) then
          WriteLn(Format('    t mod L = %s', [Trace.ToDec]))
        else
          WriteLn('    TRACE FAILED');
      end;
    end;

  finally
    SL.Free;
    H.Free;
    Trace.Free;
    P.Free;
    B.Free;
    A.Free;
  end;
end;

procedure TestPointCount(const AVal, BVal, PVal: Int64; const TestName: string);
const
  MSecsPerDay = 86400000;
var
  A, B, P, SeaResult, SchoofResult: TCnBigNumber;
  Match: Boolean;
  T1, T2: TDateTime;
  SeaMs, SchoofMs, PreGenMs: Int64;
  ModPolys: TObjectList;
  PhiL: TCnBigNumberBiPolynomial;
  QMax, QMul, BQ: TCnBigNumber;
  I, L: Integer;
begin
  WriteLn;
  WriteLn(Format('--- %s ---', [TestName]));
  A := TCnBigNumber.Create;
  B := TCnBigNumber.Create;
  P := TCnBigNumber.Create;
  SeaResult := TCnBigNumber.Create;
  SchoofResult := TCnBigNumber.Create;
  QMax := TCnBigNumber.Create;
  QMul := TCnBigNumber.Create;
  BQ := TCnBigNumber.Create;
  ModPolys := nil;
  try
    A.SetInt64(AVal);
    B.SetInt64(BVal);
    P.SetInt64(PVal);

    WriteLn(Format('  E: y^2 = x^3 + %dx + %d over F_%d', [AVal, BVal, PVal]));

    // Pre-generate modular polynomials for all needed primes
    ModPolys := TObjectList.Create(True);
    if not BigNumberSqrt(QMax, P) then Exit;
    BigNumberAddWord(QMax, 1);
    BigNumberMulWord(QMax, 4);
    QMul.SetOne;
    I := Low(CN_PRIME_NUMBERS_SQRT_UINT32);

    T1 := Now;
    while (BigNumberCompare(QMul, QMax) <= 0) and (I <= High(CN_PRIME_NUMBERS_SQRT_UINT32)) do
    begin
      L := CN_PRIME_NUMBERS_SQRT_UINT32[I];
      BigNumberSetWord(BQ, L);
      if BigNumberCompare(BQ, P) <> 0 then
      begin
        BigNumberMulWord(QMul, L);
        if L >= 3 then
        begin
          PhiL := TCnBigNumberBiPolynomial.Create;
          if CnGenerateClassicalModularPolynomial(PhiL, L) then
            ModPolys.Add(PhiL)
          else
            PhiL.Free;
        end;
      end;
      Inc(I);
    end;
    T2 := Now;
    PreGenMs := Round((T2 - T1) * MSecsPerDay);
    WriteLn(Format('  Pre-generated %d modular polynomials (%d ms)', [ModPolys.Count, PreGenMs]));

    T1 := Now;
    if CnSeaPointCount(SeaResult, A, B, P, ModPolys) then
    begin
      T2 := Now;
      SeaMs := Round((T2 - T1) * MSecsPerDay);
      WriteLn(Format('  SEA result:   #E = %s  (%d ms)', [SeaResult.ToDec, SeaMs]))
    end
    else
    begin
      T2 := Now;
      SeaMs := Round((T2 - T1) * MSecsPerDay);
      WriteLn(Format('  SEA FAILED  (%d ms)', [SeaMs]));
    end;

    T1 := Now;
    if CnEccSchoof(SchoofResult, A, B, P) then
    begin
      T2 := Now;
      SchoofMs := Round((T2 - T1) * MSecsPerDay);
      WriteLn(Format('  Schoof result: #E = %s  (%d ms)', [SchoofResult.ToDec, SchoofMs]))
    end
    else
    begin
      T2 := Now;
      SchoofMs := Round((T2 - T1) * MSecsPerDay);
      WriteLn(Format('  Schoof FAILED  (%d ms)', [SchoofMs]));
    end;

    Match := BigNumberCompare(SeaResult, SchoofResult) = 0;
    if Match then
      WriteLn('  MATCH!')
    else
      WriteLn(Format('  MISMATCH! SEA=%s Schoof=%s', [SeaResult.ToDec, SchoofResult.ToDec]));
  finally
    ModPolys.Free;
    BQ.Free;
    QMul.Free;
    QMax.Free;
    SchoofResult.Free;
    SeaResult.Free;
    P.Free;
    B.Free;
    A.Free;
  end;
end;

end.
